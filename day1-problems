#1_twosum_problem
def twoSum(nums, target):
    for i in range(len(nums)):
        for j in range(i+1, len(nums)):
            if nums[i] + nums[j] == target:
                return [i, j]


      #121_besttimetobuyandsell_problemm
      class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        buy=prices[0]
        mp=0
        for i in range(1,len(prices)):
            if (buy>prices[i]):
                buy=prices[i]
            cp=prices[i]-buy
            mp=max(cp,mp)
        return mp


      #217_contains_duplicates
      class Solution:
    def containsDuplicate(self, nums: List[int]) -> bool:
        s=set()
        for i in nums:
            if i in s:
                return True
            s.add(i)
        return False

      
#169_majority_element_problem

      class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        majority=nums[0]
        vote=1
        for i in range(1,len(nums)):
            if (vote==0):
                majority=nums[i]
                vote=1
            elif (majority==nums[i]):
                vote+=1
            else:
                vote-=1
        return  majority

      

      
